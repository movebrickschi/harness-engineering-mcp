{
  "$schema": "harness://config/schema",
  "version": "1.0",
  "project": {
    "name": "{{project_name}}",
    "type": "{{project_type}}",
    "stack": "{{stack}}",
    "mode": "small-team",
    "team_size": "2-4",
    "maturity_target": "L2"
  },
  "modules": {
    "people": {
      "branch_strategy": "github-flow",
      "pr_max_lines": 400,
      "pr_max_files": 20,
      "review_sla_hours": 24
    },
    "process": {
      "gate_review_enabled": false,
      "rollback_routing_enabled": true
    },
    "quality": {
      "coverage_baseline": 0.4,
      "local_check_max_seconds": 5
    },
    "release": {
      "semver": true,
      "changelog": true
    },
    "security": {
      "secret_scan": true,
      "sca_on_pr": true
    },
    "knowledge": {
      "feature_board": true,
      "post_mortem_required": false
    }
  }
}
